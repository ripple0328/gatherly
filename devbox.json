{
	"$schema": "https://raw.githubusercontent.com/jetpack-io/devbox/0.10.4/.schema/devbox.schema.json",
	"packages": [
		"elixir@latest",
		"postgresql@latest",
		"erlang@latest",
		"direnv@latest",
		"envchain@latest"
	],
	"env": {
		"MIX_HOME": "$PWD/.nix-mix",
		"HEX_HOME": "$PWD/.nix-hex",
		"ERL_AFLAGS": "'-kernel shell_history enabled'"
	},
	"shell": {
		"init_hook": [],
		"scripts": {
			"test": ["mix test"],
			"start": ["mix phx.server"]
		}
	}
}
